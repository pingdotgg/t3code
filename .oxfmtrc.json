{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "semi": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "ignorePatterns": [
    ".plans",
    "dist",
    "dist-electron",
    "node_modules",
    "bun.lock",
    "*.tsbuildinfo",
    "**/routeTree.gen.ts",
    "apps/web/public/mockServiceWorker.js"
  ],
  "sortPackageJson": {}
}
