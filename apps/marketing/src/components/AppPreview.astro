      const menuIconMarkup: Record<string, string> = {
        github:
          '<svg viewBox="0 0 1024 1024" fill="none" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z" transform="scale(64)" fill="currentColor"></path></svg>',
        upload:
          '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 16V4m0 0 4 4m-4-4-4 4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path><path d="M20 16.5v2A1.5 1.5 0 0 1 18.5 20h-13A1.5 1.5 0 0 1 4 18.5v-2" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path></svg>',
        commit:
          '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"></circle><path d="M3 12h6m6 0h6" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path></svg>',
        info:
          '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle><path d="M12 11v5m0-8h.01" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path></svg>',
        folder:
          '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3.75 7.5A1.75 1.75 0 0 1 5.5 5.75h4.16c.46 0 .9.183 1.224.509l1.107 1.107c.328.326.77.509 1.232.509h5.271A1.75 1.75 0 0 1 20.25 9.625v7.875A1.75 1.75 0 0 1 18.5 19.25h-13A1.75 1.75 0 0 1 3.75 17.5Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.75"></path></svg>',
      };

      const updateComposerProviderIcon = (providerId: string, iconMarkup: string) => {
        const scope = getActiveView() ?? preview;
        if (scope instanceof HTMLElement) {
          scope.dataset.selectedModelProvider = providerId;
        }

        for (const existingIcon of scope.querySelectorAll<SVGElement>("[data-preview-provider-icon]")) {
          const wrapper = document.createElement("span");
          wrapper.innerHTML = iconMarkup;
          const nextIcon = wrapper.firstElementChild;
          if (!(nextIcon instanceof SVGElement)) {
            continue;
          }

          nextIcon.classList.add("app-preview__composer-icon", "app-preview__composer-icon--provider");
          nextIcon.setAttribute("data-preview-provider-icon", "");
          nextIcon.setAttribute("data-provider", providerId);
          nextIcon.setAttribute("width", "16");
          nextIcon.setAttribute("height", "16");
          existingIcon.replaceWith(nextIcon);
        }

        const currentEffort = (getSelectedValue("effort") ?? "Low").split(" · ")[0] ?? "Low";
        updateVisibleLabels("effort", formatEffortLabel(currentEffort, providerId));
      };

      const favoriteModelKeys = new Set<string>();

      const renderModelMenu = (activeProviderId = "openai") => {
        if (!popoverItems) {
          return;
        }

        const selectedModel = getSelectedValue("model") ?? "GPT-5.4";
        const modelProviders: Record<
          string,
          {
            id: string;
            icon: string;
            label: string;
            models: string[];
            sparkle?: boolean;
            clock?: boolean;
            disabled?: boolean;
          }
        > = {
          openai: {
            id: "openai",
            icon: "openai",
            label: "Codex",
            models: ["GPT-5.5", "GPT-5.4", "GPT-5.4-Mini", "GPT-5.3-Codex", "GPT-5.3-Codex-Spark", "GPT-5.2"],
          },
          claude: {
            id: "claude",
            icon: "claude",
            label: "Claude",
            models: ["Claude Opus 4.6", "Claude Sonnet 4.6", "Claude Haiku 4.5", "Claude Sonnet 4.5"],
          },
          opencode: {
            id: "opencode",
            icon: "opencode",
            label: "OpenCode",
            models: ["Qwen 3 Coder", "GLM-4.6", "DeepSeek V3.2", "Kimi K2 Thinking"],
            sparkle: true,
          },
          cursor: {
            id: "cursor",
            icon: "cursor",
            label: "Cursor",
            models: ["Auto", "GPT-5.4", "Claude Sonnet 4.6", "Gemini 3 Pro"],
            sparkle: true,
          },
          gemini: {
            id: "gemini",
            icon: "gemini",
            label: "Gemini",
            models: ["Gemini 3 Pro", "Gemini 2.5 Pro", "Gemini 2.5 Flash"],
            clock: true,
            disabled: true,
          },
        };
        const isFavoritesView = activeProviderId === "favorites";
        const activeProvider = modelProviders[activeProviderId] ?? modelProviders.openai;
        const visibleModels = isFavoritesView
          ? Object.values(modelProviders).flatMap((provider) =>
              provider.models
                .filter((model) => favoriteModelKeys.has(modelFavoriteKey(provider.id, model)))
                .map((model) => ({ model, provider })),
            )
          : activeProvider.models.map((model) => ({ model, provider: activeProvider }));

        popoverItems.replaceChildren();

        const shell = document.createElement("div");
        shell.className = "app-preview__model-command";

        const rail = document.createElement("div");
        rail.className = "app-preview__model-rail";
        const railItems: {
          id: string;
          icon: string;
          label: string;
          sparkle?: boolean;
          clock?: boolean;
          disabled?: boolean;
        }[] = [
          { id: "favorites", icon: "star", label: "Favorites" },
          ...Object.values(modelProviders),
        ];

        for (const item of railItems) {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "app-preview__model-rail-item";
          button.dataset.provider = item.id;
          button.dataset.active = String(isFavoritesView ? item.id === "favorites" : item.id === activeProvider.id);
          button.dataset.disabled = String(Boolean(item.disabled));
          button.disabled = Boolean(item.disabled);
          button.setAttribute("aria-label", item.label);
          if (item.disabled) {
            button.setAttribute("aria-disabled", "true");
            button.title = `${item.label} coming soon`;
          }
          const icon =
            item.icon === "star" ?
              '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2.5 2.92 5.92 6.53.95-4.72 4.6 1.11 6.5L12 17.4l-5.84 3.07 1.11-6.5-4.72-4.6 6.53-.95L12 2.5Z" fill="currentColor"></path></svg>'
            : providerIconMarkup[item.icon] ?? "";
          button.innerHTML = `${icon}${item.sparkle ? '<span class="app-preview__model-rail-badge">✦</span>' : ""}${item.clock ? '<span class="app-preview__model-rail-clock"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.7"></circle><path d="M12 8v4l2.5 1.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7"></path></svg></span>' : ""}`;
          if (!item.disabled) {
            button.addEventListener("click", (event) => {
              event.preventDefault();
              event.stopPropagation();
              renderModelMenu(item.id);
            });
          }
          rail.append(button);
        }

        const content = document.createElement("div");
        content.className = "app-preview__model-command-content";
        content.innerHTML = `<label class="app-preview__model-search"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.34-4.34" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path><circle cx="11" cy="11" r="8" fill="none" stroke="currentColor" stroke-width="1.8"></circle></svg><input value="" placeholder="Search models..." /></label>`;

        const list = document.createElement("div");
        list.className = "app-preview__model-command-list";

        if (visibleModels.length === 0) {
          const empty = document.createElement("div");
          empty.className = "app-preview__model-empty";
          empty.textContent = "Star models to keep them here.";
          list.append(empty);
        }

        visibleModels.forEach(({ model, provider }, index) => {
          const row = document.createElement("button");
          row.type = "button";
          row.className = "app-preview__model-command-row";
          row.dataset.selected = String(model === selectedModel || (selectedModel === "GPT-5.4" && model === "GPT-5.4"));
          row.dataset.provider = provider.id;
          row.dataset.searchable = `${model} ${provider.label}`.toLowerCase();
          const providerIcon = providerIconMarkup[provider.icon] ?? providerIconMarkup.openai;
          const favoriteKey = modelFavoriteKey(provider.id, model);
          const isFavorite = favoriteModelKeys.has(favoriteKey);
          row.dataset.favorite = String(isFavorite);
          row.innerHTML = `<span class="app-preview__model-favorite" role="button" tabindex="0" aria-label="${isFavorite ? "Unstar" : "Star"} ${model}"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2.5 2.92 5.92 6.53.95-4.72 4.6 1.11 6.5L12 17.4l-5.84 3.07 1.11-6.5-4.72-4.6 6.53-.95L12 2.5Z" fill="${isFavorite ? "currentColor" : "none"}" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8"></path></svg></span><span class="app-preview__model-row-copy"><strong>${model}</strong><small>${providerIcon}<span>${provider.label}</span></small></span><kbd>⌘${index + 1}</kbd>`;
          const favoriteButton = row.querySelector<HTMLElement>(".app-preview__model-favorite");
          const toggleFavorite = () => {
            if (favoriteModelKeys.has(favoriteKey)) {
              favoriteModelKeys.delete(favoriteKey);
            } else {
              favoriteModelKeys.add(favoriteKey);
            }
            renderModelMenu(activeProviderId);
          };
          favoriteButton?.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            toggleFavorite();
          });
          favoriteButton?.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") {
              return;
            }
            event.preventDefault();
            event.stopPropagation();
            toggleFavorite();
          });
          row.addEventListener("click", () => {
            updateVisibleLabels("model", model);
            updateComposerProviderIcon(provider.id, providerIcon);
            if (popover) {
              popover.hidden = true;
            }
          });
          list.append(row);
        });

        content.append(list);
        const input = content.querySelector<HTMLInputElement>("input");
        input?.addEventListener("input", () => {
          const query = input.value.trim().toLowerCase();
          for (const row of list.querySelectorAll<HTMLElement>("[data-searchable]")) {
            row.hidden = query.length > 0 && !(row.dataset.searchable ?? "").includes(query);
          }
        });

        shell.append(rail, content);
        popoverItems.append(shell);
        window.setTimeout(() => input?.focus(), 0);
      };

      const renderRadioMenu = (menuName: string) => {
        if (!popoverItems) {
          return;
        }

        const selectedEffortLabel = getSelectedValue("effort") ?? "Low · Fast";
        const selectedEffort = selectedEffortLabel.split(" · ")[0] ?? "Low";
        const selectedProvider = getSelectedProvider();
        const showFastMode = selectedProvider === "openai";
        const selectedFastMode = showFastMode && getSelectedFastMode();
        const selectedAccess = getSelectedValue("access") ?? "Full access";
        const effortOptions = [
          { label: "Low", detail: "" },
          { label: "Medium", detail: "" },
          { label: "High", detail: "" },
          { label: "Extra high", detail: "" },
        ] satisfies { label: string; detail?: string }[];
        const accessOptions: { label: string; value: string; detail: string }[] = [
          {
            label: "Supervised",
            value: "approval-required",
            detail: "Ask before commands and file changes.",
          },
          {
            label: "Auto-accept edits",
            value: "auto-accept-edits",
            detail: "Auto-approve edits, ask before other actions.",
          },
          {
            label: "Full access",
            value: "full-access",
            detail: "Allow commands and edits without prompts.",
          },
        ];

        const section = document.createElement("div");
        section.className = menuName === "effort" ? "app-preview__select-section app-preview__select-section--effort" : "app-preview__select-section app-preview__select-section--access";
        if (menuName === "effort") {
          const label = document.createElement("div");
          label.className = "app-preview__select-label";
          label.textContent = "Reasoning";
          section.append(label);
        }

        const options = menuName === "effort" ? effortOptions : accessOptions;
        for (const option of options) {
          const selected = menuName === "effort" ? option.label === selectedEffort : option.label === selectedAccess;
          const button = document.createElement("button");
          button.type = "button";
          button.className = menuName === "access" ? "app-preview__select-item app-preview__select-item--access" : "app-preview__select-item app-preview__select-item--effort";
          button.dataset.selected = String(selected);
          const accessValue = "value" in option && typeof option.value === "string" ? option.value : "";
          const icon = menuName === "access" ? (accessIconMarkup[accessValue] ?? "") : "";
          const checkIcon = selected ? '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.252 12.7 10.2 18.63 18.748 5.37" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>' : "";
          button.innerHTML = `<span class="app-preview__select-check">${checkIcon}</span><span class="app-preview__select-copy">${menuName === "access" ? `<span class="app-preview__select-icon">${icon}</span>` : ""}<span><strong>${option.label}${menuName === "effort" && option.label === "Medium" ? " (default)" : ""}</strong>${option.detail ? `<small>${option.detail}</small>` : ""}</span></span>`;
          button.addEventListener("click", () => {
            if (menuName === "effort") {
              updateVisibleLabels("effort", formatEffortLabel(option.label, selectedProvider));
            } else {
              updateVisibleLabels("access", option.label);
              if (accessValue) {
                updateAccessIcon(accessValue);
              }
            }
            if (popover) {
              popover.hidden = true;
            }
          });
          section.append(button);
        }

        if (menuName === "effort" && showFastMode) {
          const separator = document.createElement("div");
          separator.className = "app-preview__select-separator";
          section.append(separator);

          const fastLabel = document.createElement("div");
          fastLabel.className = "app-preview__select-label app-preview__select-label--fast";
          fastLabel.textContent = "Fast Mode";
          section.append(fastLabel);

          for (const option of ["On", "Off"]) {
            const selected = selectedFastMode ? option === "On" : option === "Off";
            const button = document.createElement("button");
            button.type = "button";
            button.className = "app-preview__select-item app-preview__select-item--effort";
            button.dataset.selected = String(selected);
            const checkIcon = selected ? '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.252 12.7 10.2 18.63 18.748 5.37" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>' : "";
            button.innerHTML = `<span class="app-preview__select-check">${checkIcon}</span><span class="app-preview__select-copy"><span><strong>${option}</strong></span></span>`;
            button.addEventListener("click", () => {
              const fastModeEnabled = option === "On";
              setSelectedFastMode(fastModeEnabled);
              updateVisibleLabels("effort", fastModeEnabled ? `${selectedEffort} · Fast` : selectedEffort);
              if (popover) {
                popover.hidden = true;
              }
            });
            section.append(button);
          }
        }

        popoverItems.replaceChildren(section);
      };

      const renderWorkspaceMenu = () => {
        if (!popoverItems) {
          return;
        }

        const selectedWorkspace = getSelectedValue("worktree") ?? "Current checkout";
        const options = [
          {
            label: "Current checkout",
            value: "local",
            icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.75 7.5A1.75 1.75 0 0 1 5.5 5.75h4.16c.46 0 .9.183 1.224.509l1.107 1.107c.328.326.77.509 1.232.509h5.271A1.75 1.75 0 0 1 20.25 9.625v7.875A1.75 1.75 0 0 1 18.5 19.25h-13A1.75 1.75 0 0 1 3.75 17.5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.75"></path></svg>',
          },
          {
            label: "New worktree",
            value: "worktree",
            icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.75 7.5A1.75 1.75 0 0 1 5.5 5.75h4.16c.46 0 .9.183 1.224.509l1.107 1.107c.328.326.77.509 1.232.509h5.271A1.75 1.75 0 0 1 20.25 9.625v7.875A1.75 1.75 0 0 1 18.5 19.25h-13A1.75 1.75 0 0 1 3.75 17.5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.75"></path><path d="M8.5 14.25h7M12 10.75v7" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.75"></path></svg>',
          },
        ];

        const section = document.createElement("div");
        section.className = "app-preview__select-section app-preview__select-section--workspace";
        const label = document.createElement("div");
        label.className = "app-preview__select-label";
        label.textContent = "Workspace";
        section.append(label);

        for (const option of options) {
          const selected = option.label === selectedWorkspace;
          const button = document.createElement("button");
          button.type = "button";
          button.className = "app-preview__select-item app-preview__select-item--workspace";
          button.dataset.selected = String(selected);
          const checkIcon = selected ? '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.252 12.7 10.2 18.63 18.748 5.37" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>' : "";
          button.innerHTML = `<span class="app-preview__select-check">${checkIcon}</span><span class="app-preview__select-copy"><span class="app-preview__select-icon">${option.icon}</span><span><strong>${option.label}</strong></span></span>`;
          button.addEventListener("click", () => {
            updateVisibleLabels("worktree", option.label);
            const currentBranch = getSelectedValue("branch") ?? "main";
            updateVisibleLabels("branch", option.value === "worktree" ? `From ${currentBranch.replace(/^From /, "")}` : currentBranch.replace(/^From /, ""));
            if (popover) {
              popover.hidden = true;
            }
          });
          section.append(button);
        }

        popoverItems.replaceChildren(section);
      };

      const renderBranchMenu = () => {
        if (!popoverItems) {
          return;
        }

        const selectedBranch = (getSelectedValue("branch") ?? "main").replace(/^From /, "");
        const branches = [
          { name: "main", badge: "current" },
          { name: "t3code/marketing-ui-mirror", badge: "worktree" },
          { name: "feature/thread-hotkeys", badge: "" },
          { name: "release/homepage-polish", badge: "remote" },
          { name: "docs/agent-browser-copy", badge: "" },
          { name: "theo/screenshot-pass", badge: "default" },
        ];

        const shell = document.createElement("div");
        shell.className = "app-preview__branch-combobox";
        shell.innerHTML = `
          <div class="app-preview__branch-search">
            <input type="text" placeholder="Search branches..." aria-label="Search branches" />
          </div>
          <div class="app-preview__branch-list"></div>
          <div class="app-preview__branch-empty" hidden>No branches found.</div>
        `;
        const input = shell.querySelector<HTMLInputElement>("input");
        const list = shell.querySelector<HTMLElement>(".app-preview__branch-list");
        const empty = shell.querySelector<HTMLElement>(".app-preview__branch-empty");

        const renderRows = () => {
          if (!list || !empty) {
            return;
          }
          const query = input?.value.trim().toLowerCase() ?? "";
          list.replaceChildren();
          const visibleBranches = branches.filter((branch) => branch.name.toLowerCase().includes(query));
          if (query && !visibleBranches.some((branch) => branch.name === query)) {
            const createButton = document.createElement("button");
            createButton.type = "button";
            createButton.className = "app-preview__branch-item";
            const createLabel = document.createElement("span");
            createLabel.textContent = `Create new branch "${query}"`;
            createButton.append(createLabel);
            createButton.addEventListener("click", () => {
              const workspace = getSelectedValue("worktree") ?? "Current checkout";
              updateVisibleLabels("branch", workspace === "New worktree" ? `From ${query}` : query);
              if (popover) {
                popover.hidden = true;
              }
            });
            list.append(createButton);
          }
          for (const branch of visibleBranches) {
            const button = document.createElement("button");
            button.type = "button";
            button.className = "app-preview__branch-item";
            button.dataset.selected = String(branch.name === selectedBranch);
            button.innerHTML = `<span>${branch.name}</span>${branch.badge ? `<small>${branch.badge}</small>` : ""}`;
            button.addEventListener("click", () => {
              const workspace = getSelectedValue("worktree") ?? "Current checkout";
              updateVisibleLabels("branch", workspace === "New worktree" ? `From ${branch.name}` : branch.name);
              if (popover) {
                popover.hidden = true;
              }
            });
            list.append(button);
          }
          empty.hidden = list.children.length > 0;
        };

        input?.addEventListener("input", renderRows);
        renderRows();
        popoverItems.replaceChildren(shell);
        window.setTimeout(() => input?.focus(), 0);
      };

      const openMenu = (menuName: string, trigger: HTMLElement) => {
        const menu = previewMenuOptions[menuName];
        if (!menu || !popover || !popoverTitle || !popoverItems) {
          return;
        }

        const anchorElement =
          menuName === "open" || menuName === "push" ?
            (trigger.closest(".app-preview__action-group") as HTMLElement | null) ?? trigger
          : trigger;

        if (!popover.hidden && popover.dataset.previewOpenMenu === menuName && openMenuTrigger === anchorElement) {
          popover.hidden = true;
          openMenuTrigger = null;
          return;
        }

        popover.dataset.previewOpenMenu = menuName;
        openMenuTrigger = anchorElement;
        popoverTitle.textContent = menu.title;
        const menuWidth = menu.width ?? 238;
        popover.style.width = `${menuWidth}px`;
        if (menuName === "model") {
          popoverTitle.textContent = "";
          popover.style.width = "440px";
          renderModelMenu(getSelectedProvider());
        } else if (menuName === "effort" || menuName === "access") {
          popoverTitle.textContent = "";
          popover.style.width = menuName === "access" ? "264px" : "190px";
          renderRadioMenu(menuName);
        } else if (menuName === "worktree") {
          popoverTitle.textContent = "";
          popover.style.width = "190px";
          renderWorkspaceMenu();
        } else if (menuName === "branch") {
          popoverTitle.textContent = "";
          popover.style.width = "320px";
          renderBranchMenu();
        } else {
          popoverItems.replaceChildren(
            ...menu.sections.flatMap((section) => {
              const nodes: HTMLElement[] = [];
              if (section.label) {
                const label = document.createElement("div");
                label.className = "app-preview__popover-section";
                label.textContent = section.label;
                nodes.push(label);
              }

              for (const item of section.items) {
                const selected = getSelectedValue(item.target) === item.label;
                const button = document.createElement("button");
                button.type = "button";
                button.className = "app-preview__popover-item";
                button.dataset.tone = item.tone ?? "default";
                button.dataset.selected = String(selected);
                const icon = item.icon ? (menuIconMarkup[item.icon] ?? "") : "";
                const shortcutMarkup =
                  menuName === "open" && item.shortcut === "⌘O" ?
                    '<kbd><span class="app-preview__shortcut-meta">⌘</span><span class="app-preview__shortcut-letter">O</span></kbd>'
                  : item.shortcut ?
                    `<kbd>${item.shortcut}</kbd>`
                  : "";
                button.innerHTML = `${icon ? `<span class="app-preview__popover-icon">${icon}</span>` : `<span class="app-preview__popover-check">${selected ? "✓" : ""}</span>`}<span class="app-preview__popover-copy"><span>${item.label}</span>${item.detail ? `<small>${item.detail}</small>` : ""}</span>${shortcutMarkup}`;
                button.addEventListener("click", () => {
                  updateVisibleLabels(item.target, item.label);
                  if (item.action === "collapse-all" || item.action === "expand-all") {
                    const collapsed = item.action === "collapse-all";
                    for (const project of preview.querySelectorAll<HTMLElement>("[data-preview-project]")) {
                      project.dataset.collapsed = String(collapsed);
                      project.querySelector<HTMLElement>("[data-preview-project-toggle]")?.setAttribute("aria-expanded", String(!collapsed));
                    }
                  }
                  popover.hidden = true;
                  openMenuTrigger = null;
                });
                nodes.push(button);
              }

              return nodes;
            }),
          );
        }

        const previewRect = preview.getBoundingClientRect();
        const triggerRect = anchorElement.getBoundingClientRect();
        const actualMenuWidth =
          menuName === "model" ? 440
          : menuName === "access" ? 264
          : menuName === "effort" ? 190
          : menuName === "worktree" ? 190
          : menuName === "branch" ? 320
          : menuName === "push" ? 176
          : menuName === "open" ? 144
          : menuWidth;
        const maxLeft = Math.max(8, previewRect.width - actualMenuWidth - 8);
        popover.hidden = false;
        popover.style.visibility = "hidden";
        const popoverHeight = popover.offsetHeight;
        popover.style.left = `${Math.max(8, Math.min(triggerRect.left - previewRect.left, maxLeft))}px`;
        popover.style.top =
          menuName === "model" || menuName === "effort" || menuName === "access" || menuName === "worktree" || menuName === "branch" ?
            `${Math.max(8, triggerRect.top - previewRect.top - popoverHeight - 8)}px`
          : `${Math.min(triggerRect.bottom - previewRect.top + 6, previewRect.height - 190)}px`;
        popover.style.visibility = "";
      };

      preview.addEventListener("click", (event) => {
        const element = event.target instanceof Element ? event.target : null;
        const selectedThread = element?.closest<HTMLElement>("[data-preview-select]");
        const menuTrigger = element?.closest<HTMLElement>("[data-preview-menu]");
        const iconToggle = element?.closest<HTMLButtonElement>("[data-preview-toggle]");
        const modeToggle = element?.closest<HTMLButtonElement>("[data-preview-mode-toggle]");
        const scrollBottomTrigger = element?.closest<HTMLElement>("[data-preview-scroll-bottom]");
        const projectToggle = element?.closest<HTMLElement>("[data-preview-project-toggle]");
        const sortTrigger = element?.closest<HTMLElement>("[data-preview-sort]");
        if (popover && !popover.hidden && !menuTrigger && (!element || !popover.contains(element))) {
          closeTransient();
        }

        if (scrollBottomTrigger && preview.contains(scrollBottomTrigger)) {
          const threadId = scrollBottomTrigger.closest<HTMLElement>("[data-preview-view]")?.dataset.previewThreadId;
          if (threadId) scrollTimelineToBottom(threadId);
          return;
        }

        if (sortTrigger && preview.contains(sortTrigger)) {
          const list = preview.querySelector<HTMLElement>("[data-preview-project-list]");
          if (!list) return;
          const projects = Array.from(list.querySelectorAll<HTMLElement>("[data-preview-project]"));
          const sorted = preview.getAttribute("data-project-sort") !== "alpha";
          preview.setAttribute("data-project-sort", sorted ? "alpha" : "original");
          projects
            .toSorted((a, b) =>
              sorted
                ? (a.dataset.projectId ?? "").localeCompare(b.dataset.projectId ?? "")
                : Number(a.dataset.projectIndex ?? 0) - Number(b.dataset.projectIndex ?? 0),
            )
            .forEach((project) => list.append(project));
          return;
        }

        if (projectToggle && preview.contains(projectToggle)) {
          const project = projectToggle.closest<HTMLElement>("[data-preview-project]");
          if (!project) return;
          const collapsed = project.dataset.collapsed !== "true";
          project.dataset.collapsed = String(collapsed);
          projectToggle.setAttribute("aria-expanded", String(!collapsed));
          return;
        }

        if (modeToggle && preview.contains(modeToggle)) {
          const currentMode = getSelectedValue("mode") ?? "Build";
          const nextMode = currentMode === "Plan" ? "Build" : "Plan";
          updateVisibleLabels("mode", nextMode);
          modeToggle.title =
            nextMode === "Plan" ?
              "Plan mode — click to return to normal build mode"
            : "Default mode — click to enter plan mode";
          closeTransient();
          return;
        }

        if (iconToggle && preview.contains(iconToggle)) {
          const pressed = iconToggle.dataset.pressed === "true";
          iconToggle.dataset.pressed = String(!pressed);
          iconToggle.setAttribute("aria-pressed", String(!pressed));
          closeTransient();
          return;
        }

        if (menuTrigger && preview.contains(menuTrigger)) {
          openMenu(menuTrigger.dataset.previewMenu ?? "", menuTrigger);
          return;
        }

        if (!selectedThread || !preview.contains(selectedThread)) {
          return;
        }

        const threadId = selectedThread.dataset.previewSelect;
        if (!threadId) {
          return;
        }

        setActiveThread(threadId);
      });

      document.addEventListener("keydown", (event: KeyboardEvent) => {
        if (!(event.target instanceof Node) || !preview.contains(event.target)) {
          return;
        }

        if (event.key === "Escape") {
          closeTransient();
        }
      });
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAppPreviewThreads, { once: true });
  } else {
    initAppPreviewThreads();
  }
</script>

