<script>
  type PreviewMenuItem = {
    label: string;
    detail?: string;
    icon?: string;
    target?: string;
    shortcut?: string;
    tone?: "default" | "muted" | "danger";
    action?: "collapse-all" | "expand-all";
  };

  type PreviewMenuSection = {
    label?: string;
    items: PreviewMenuItem[];
  };

  const previewMenuOptions: Record<string, { title: string; width?: number; sections: PreviewMenuSection[] }> = {
    open: {
      title: "Open",
      width: 144,
      sections: [
        {
          items: [
            { label: "Finder", icon: "folder", shortcut: "⌘O" },
          ],
        },
      ],
    },
    push: {
      title: "Git actions",
      width: 274,
      sections: [
        {
          items: [
            { label: "Commit", icon: "commit" },
            { label: "Push", icon: "upload", tone: "muted" },
            { label: "Create PR", icon: "github", tone: "muted" },
          ],
        },
      ],
    },
  };

  const modelFavoriteKey = (providerId: string, model: string) => `${providerId}:${model}`;
  const accessIconMarkup: Record<string, string> = {
    "approval-required":
      '<svg class="app-preview__composer-icon" data-preview-access-icon data-access-mode="approval-required" viewBox="0 0 24 24" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path></svg>',
    "auto-accept-edits":
      '<svg class="app-preview__composer-icon" data-preview-access-icon data-access-mode="auto-accept-edits" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path><path d="m16.5 3.5 4 4L7 21H3v-4L16.5 3.5Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>',
    "full-access":
      '<svg class="app-preview__composer-icon" data-preview-access-icon data-access-mode="full-access" viewBox="0 0 24 24" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2"></rect><path d="M7 11V7a5 5 0 0 1 9.9-1" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path></svg>',
  };

  const initAppPreviewThreads = () => {
    for (const preview of document.querySelectorAll(".app-preview")) {
      const previewElement = preview as HTMLElement;
      if (previewElement.dataset.previewInitialized === "true") {
        continue;
      }
      previewElement.dataset.previewInitialized = "true";

      const popover = preview.querySelector<HTMLElement>("[data-preview-popover]");
      const popoverTitle = preview.querySelector<HTMLElement>("[data-preview-popover-title]");
      const popoverItems = preview.querySelector<HTMLElement>("[data-preview-popover-items]");
      let openMenuTrigger: HTMLElement | null = null;

      const syncComposerPlaceholder = (threadId: string) => {
        const input = preview.querySelector<HTMLElement>(
          `[data-preview-composer-input][data-preview-thread-id="${CSS.escape(threadId)}"]`,
        );
        const placeholder = preview.querySelector<HTMLElement>(
          `[data-preview-composer-placeholder][data-preview-thread-id="${CSS.escape(threadId)}"]`,
        );
        if (!input || !placeholder) {
          return;
        }

        placeholder.hidden = (input.textContent ?? "").trim().length > 0;
      };

      const closeTransient = () => {
        if (popover) {
          popover.hidden = true;
          openMenuTrigger = null;
        }
      };

      const setActiveThread = (threadId: string) => {
        preview.setAttribute("data-active-thread", threadId);

        for (const input of preview.querySelectorAll<HTMLInputElement>(".app-preview__state")) {
          input.checked = input.id === `app-preview-${threadId}`;
        }

        for (const view of preview.querySelectorAll<HTMLElement>("[data-preview-view]")) {
          view.hidden = view.dataset.previewThreadId !== threadId;
        }

        for (const thread of preview.querySelectorAll<HTMLElement>("[data-preview-thread-id]")) {
          if (thread.matches("[data-preview-view]")) {
            continue;
          }

          thread.dataset.active = String(thread.dataset.previewThreadId === threadId);
        }

        syncScrollBottomButton(threadId);
        closeTransient();
      };

      for (const view of preview.querySelectorAll<HTMLElement>("[data-preview-view]")) {
        const threadId = view.dataset.previewThreadId;
        const timeline = view.querySelector<HTMLElement>("[data-preview-timeline]");
        if (!threadId || !timeline) continue;

        timeline.addEventListener("scroll", () => syncScrollBottomButton(threadId), { passive: true });
        syncScrollBottomButton(threadId);
      }

      for (const composerInput of preview.querySelectorAll<HTMLElement>("[data-preview-composer-input]")) {
        const threadId = composerInput.dataset.previewThreadId;
        if (!threadId) {
          continue;
        }

        syncComposerPlaceholder(threadId);
        composerInput.addEventListener("input", () => {
          syncComposerPlaceholder(threadId);
        });
      }

      const getActiveView = () => {
        const activeThreadId = previewElement.dataset.activeThread;
        if (!activeThreadId) {
          return null;
        }

        return preview.querySelector<HTMLElement>(`[data-preview-view][data-preview-thread-id="${CSS.escape(activeThreadId)}"]`);
      };

      const updateVisibleLabels = (target: string | undefined, value: string) => {
        if (!target) {
          return;
        }

        const scope = getActiveView() ?? preview;
        for (const label of scope.querySelectorAll<HTMLElement>(`[data-preview-label="${CSS.escape(target)}"]`)) {
          label.textContent = value;
        }
      };

      const getSelectedFastMode = () => {
        const scope = getActiveView() ?? previewElement;
        if (scope instanceof HTMLElement && scope.dataset.selectedFastMode) {
          return scope.dataset.selectedFastMode === "true";
        }

        const isFast = (getSelectedValue("effort") ?? "Low · Fast").includes("Fast");
        if (scope instanceof HTMLElement) {
          scope.dataset.selectedFastMode = String(isFast);
        }
        return isFast;
      };

      const setSelectedFastMode = (enabled: boolean) => {
        const scope = getActiveView() ?? previewElement;
        if (scope instanceof HTMLElement) {
          scope.dataset.selectedFastMode = String(enabled);
        }
      };

      const formatEffortLabel = (effort: string, providerId = getSelectedProvider()) => {
        return providerId === "openai" && getSelectedFastMode() ? `${effort} · Fast` : effort;
      };

      const updateAccessIcon = (mode: string) => {
        const scope = getActiveView() ?? preview;
        for (const existingIcon of scope.querySelectorAll<SVGElement>("[data-preview-access-icon]")) {
          const wrapper = document.createElement("span");
          wrapper.innerHTML = accessIconMarkup[mode] ?? accessIconMarkup["full-access"];
          const nextIcon = wrapper.firstElementChild;
          if (!(nextIcon instanceof SVGElement)) {
            continue;
          }
          nextIcon.setAttribute("width", "16");
          nextIcon.setAttribute("height", "16");
          existingIcon.replaceWith(nextIcon);
        }
      };

      function syncScrollBottomButton(threadId: string) {
        const view = preview.querySelector<HTMLElement>(`[data-preview-view][data-preview-thread-id="${CSS.escape(threadId)}"]`);
        const timeline = view?.querySelector<HTMLElement>("[data-preview-timeline]");
        const buttonWrap = view?.querySelector<HTMLElement>("[data-preview-scroll-bottom-wrap]");
        if (!buttonWrap) return;
        if (!timeline) {
          buttonWrap.hidden = true;
          return;
        }

        const distanceFromBottom = timeline.scrollHeight - timeline.clientHeight - timeline.scrollTop;
        buttonWrap.hidden = timeline.scrollHeight <= timeline.clientHeight + 1 || distanceFromBottom < 24;
      }

      function scrollTimelineToBottom(threadId: string) {
        const view = preview.querySelector<HTMLElement>(`[data-preview-view][data-preview-thread-id="${CSS.escape(threadId)}"]`);
        const timeline = view?.querySelector<HTMLElement>("[data-preview-timeline]");
        if (!timeline) return;

        timeline.scrollTo({ top: timeline.scrollHeight, behavior: "smooth" });
        window.setTimeout(() => syncScrollBottomButton(threadId), 180);
      }

      const getSelectedValue = (target: string | undefined) => {
        if (!target) {
          return null;
        }

        const scope = getActiveView() ?? preview;
        return scope.querySelector<HTMLElement>(`[data-preview-label="${CSS.escape(target)}"]`)?.textContent?.trim() ?? null;
      };

      const getSelectedProvider = () => {
        const activeView = getActiveView();
        return activeView?.dataset.selectedModelProvider ?? activeView?.querySelector<SVGElement>("[data-preview-provider-icon]")?.dataset.provider ?? "openai";
      };

