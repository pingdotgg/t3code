  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
