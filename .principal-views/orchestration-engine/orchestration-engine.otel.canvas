      "fromSide": "bottom",
      "toSide": "top",
      "pv": { "edgeType": "sequence" }
    },
    {
      "id": "receipt-to-hit",
      "fromNode": "command-receipt-checked",
      "toNode": "command-idempotent-hit",
      "fromSide": "right",
      "toSide": "left",
      "pv": { "edgeType": "branch" }
    },
    {
      "id": "receipt-to-rejected",
      "fromNode": "command-receipt-checked",
      "toNode": "command-previously-rejected",
      "fromSide": "right",
