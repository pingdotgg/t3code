      "toSide": "top",
      "pv": { "edgeType": "sequence" }
    },
    {
      "id": "append-to-commit",
      "fromNode": "command-event-appended",
      "toNode": "command-transaction-committed",
      "fromSide": "bottom",
      "toSide": "top",
      "pv": { "edgeType": "sequence" }
    },
    {
      "id": "commit-to-completed",
