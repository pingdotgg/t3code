{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false,
    "paths": {
      "~/*": ["../../apps/web/src/*"]
    },
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "globalConsole": "off"
        }
      }
    ]
  },
  "include": ["server", "web", "../../apps/web/src/*.d.ts"]
}
